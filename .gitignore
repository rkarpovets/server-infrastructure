# Ansible
*.retry
collections/

# Vault password - NEVER commit (kept in $HOME)
.ansible_vault_pass
*vault_pass*

# Stateful data restored outside IaC - NEVER commit (VPN keys, TLS, databases)
*.db
x-ui.db
*.tgz
*.pem
*.key
*.crt
*.p12
infra-state*/

# SSH keys - never let a private key slip into the repo
id_rsa*
id_ed25519*
*.ppk

# Local env / secret overrides
.env
.env.*
*.local.yml

# Ansible runtime fact cache / artifacts
*.log
fact_cache/

# Editor / OS
*.swp
*~
.DS_Store
.idea/
.vscode/
_rendered/
