#!/bin/sh
# {{ ansible_managed }}
# Steer hardware IRQs away from the isolated core {{ host_tuning_isolated_cpu }}.
# irqbalance is not installed on this host, so affinity is set directly.
# Some IRQs (per-CPU timers, chained controllers) reject affinity writes -
# that is expected and safe to ignore.

echo {{ host_tuning_irq_affinity_mask }} > /proc/irq/default_smp_affinity

for f in /proc/irq/*/smp_affinity; do
    echo {{ host_tuning_irq_affinity_mask }} > "$f" 2>/dev/null || true
done
