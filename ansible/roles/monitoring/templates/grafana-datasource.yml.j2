apiVersion: 1
datasources:
  - name: Prometheus
    uid: prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: true
  - name: Loki
    uid: loki
    type: loki
    access: proxy
    # Loki runs in the same namespace (logging role) - plain service DNS.
    # Until the logging phase is deployed this datasource just sits unused.
    url: http://loki:3100
    isDefault: false
    jsonData:
      # Lets you jump metrics -> logs by shared labels in Grafana Explore
      maxLines: 1000