{
  "uid": "host-cpu",
  "title": "Host CPU (per core)",
  "tags": ["host"],
  "timezone": "utc",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Busiest core now",
      "description": "Highest single-core busy %. With one core isolated for the single-threaded game, the busiest core is what predicts gameplay impact - the 4-core average hides it.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 70 },
            { "color": "red", "value": 85 } ] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(100 - (avg by (cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100))" }
      ]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Cores right now",
      "description": "cpu 3 is the isolated game core; 0-2 carry everything else (k3s, system, the evicted mod.io thread).",
      "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 70 },
            { "color": "red", "value": 85 } ] } },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg by (cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "core {{cpu}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU per core (%)",
      "description": "Per-core busy %. The game is single-threaded, so one core can saturate while the average stays low.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg by (cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "core {{cpu}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Load average vs cores",
      "description": "Runnable tasks vs the 4 cores available. Sustained load above the core count means queuing.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "min": 0, "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "cores" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_load1", "legendFormat": "load 1m" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_load15", "legendFormat": "load 15m" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(count by (cpu) (node_cpu_seconds_total))", "legendFormat": "cores" }
      ]
    }
  ]
}
