{
  "uid": "iss-server",
  "title": "Insurgency: Sandstorm",
  "tags": ["iss"],
  "timezone": "utc",
  "editable": true,
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtin": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "hide": false,
        "iconColor": "semi-dark-blue",
        "name": "Map change",
        "target": {
          "refId": "Anno",
          "queryType": "range",
          "expr": "{job=\"sandstorm\"} |= \"Loading scenario asset\" | regexp \"Scenario_(?P<scn>[^']+)'\" | line_format \"\\ud83d\\uddfa {{.scn}}\""
        }
      },
      {
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": false,
        "hide": false,
        "iconColor": "semi-dark-red",
        "name": "Player left",
        "target": {
          "refId": "Anno",
          "queryType": "range",
          "expr": "{job=\"sandstorm\"} |= \"disconnected\" |= \"say\" | regexp \"say (?P<who>.+) disconnected\" | line_format \"\\u2b05 {{.who}}\""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "type": "stat",
      "title": "Current scenario",
      "description": "Map + side: _S = playing as Security, _I = as Insurgents.",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "text" }, "noValue": "-" },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "none", "textMode": "name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(iss_map_info == 1, \"s\", \"$1\", \"side\", \"^(.).*\")",
          "legendFormat": "{{map}}_{{s}}", "instant": true }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Players online",
      "description": "Live player count out of the configured slots (see the dashed line in the trend panel).",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iss_players_online", "instant": false }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Game core load",
      "description": "Busy % of the isolated core (cpu 3) that runs ONLY the game process. This is the number that decides tick stability.",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 70 },
            { "color": "red", "value": 85 } ] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{cpu=\"3\",mode=\"idle\"}[2m])) * 100)", "instant": false }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Players online",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "min": 0, "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "stepAfter", "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "slots" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iss_players_online", "legendFormat": "players" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iss_players_max", "legendFormat": "slots" }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Game core load (%)",
      "description": "Only the isolated game core (cpu 3). Shares the crosshair with the players panel - move the cursor to correlate load with player count.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" } },
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "transparent", "value": null },
            { "color": "red", "value": 85 } ] } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{cpu=\"3\",mode=\"idle\"}[2m])) * 100)", "legendFormat": "game core" }
      ]
    },
    {
      "id": 30,
      "type": "state-timeline",
      "title": "Map history",
      "description": "Which scenario was live when. _S = Security, _I = Insurgents.",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 70, "lineWidth": 0 },
          "color": { "mode": "palette-classic" },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "" } } }
          ]
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "never", "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(iss_map_info == 1, \"s\", \"$1\", \"side\", \"^(.).*\")",
          "legendFormat": "{{map}}_{{s}}" }
      ]
    },
    {
      "id": 40,
      "type": "logs",
      "title": "Server logs (live)",
      "description": "Game log via Loki. listplayers RCON polling is filtered out.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending", "prettifyLogMessage": false },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "queryType": "range", "expr": "{job=\"sandstorm\"} != \"listplayers\"" }
      ]
    }
  ]
}
