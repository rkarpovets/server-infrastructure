apiVersion: v1
kind: Namespace
metadata:
  name: {{ sandstorm_namespace }}
---
# The game pod. Two containers (game + RCON manager sidecar), NO
# shareProcessNamespace: the manager talks to the game exclusively over RCON.
#
# Nothing here auto-restarts the game (no config checksum annotations on
# purpose): a game restart kicks live players, so applying config/.env
# changes is always a manual `kubectl -n {{ sandstorm_namespace }} rollout
# restart deployment sandstorm` in a no-players window.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sandstorm
  namespace: {{ sandstorm_namespace }}
  labels:
    app: sandstorm
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: sandstorm
  template:
    metadata:
      labels:
        app: sandstorm
    spec:
      # Same network position as the systemd unit had: UDP game/query ports
      # on the host, RCON on loopback shared with the sidecar.
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      securityContext:
        # The whole /home/steam tree is a hostPath owned by steam. The uid is
        # resolved from the host at deploy time (getent in the role tasks) -
        # NOT hardcoded: on this host steam is 1001, not the 1000 the
        # migration plan assumed.
        runAsUser: {{ getent_passwd[sandstorm_user][1] }}
        runAsGroup: {{ getent_passwd[sandstorm_user][2] }}
      terminationGracePeriodSeconds: 60
      containers:
        - name: game
          image: {{ sandstorm_game_image }}
          workingDir: {{ sandstorm_install_dir }}
          # taskset pins the whole process onto the isolated core; the
          # host-side modio-affinity timer then evicts the hot
          # ModioBackground thread back to the general cores (it can see and
          # re-pin container threads through the host /proc).
          command:
            - /bin/bash
            - -c
            - exec taskset -c {{ host_tuning_isolated_cpu }} ./server.sh
          env:
            # runAsUser is the HOST steam uid, which has no /etc/passwd entry
            # inside the image - without it HOME falls back to "/" and
            # server.sh silently sources a nonexistent /.env (empty ports,
            # empty tokens, default map - the whole boot goes sideways).
            - name: HOME
              value: {{ sandstorm_home }}
          # Second line of defense (the manager heals what RCON can reach):
          # if the game hangs so hard it stops logging, k8s restarts the pod.
          #
          # NOT a tcpSocket probe on the RCON port: ISS leaks a server-side
          # FRconConnection thread for EVERY accepted connection, so a probe
          # that connects every periodSeconds piles up leaked threads (~1 per
          # probe) and slowly saturates the isolated core. Instead we check the
          # game log is still being written - the manager's RCON poll alone
          # touches it every ~20s, so a stale log means the game is truly hung.
          livenessProbe:
            exec:
              command:
                - /bin/sh
                - -c
                - test $(( $(date +%s) - $(stat -c %Y "{{ sandstorm_install_dir }}/Insurgency/Saved/Logs/Insurgency.log") )) -lt 120
            # Mods + first map load take minutes - do not shoot early.
            initialDelaySeconds: 240
            periodSeconds: 30
            failureThreshold: 4
          volumeMounts:
            - name: steam-home
              mountPath: {{ sandstorm_home }}
        - name: manager
          image: {{ sandstorm_manager_image }}
          workingDir: {{ sandstorm_home }}/sandstorm_server
          # Deps land in an ephemeral dir, not the host home - the host venv
          # was built for the host python and is not reused here.
          command:
            - /bin/sh
            - -c
            - >-
              pip install --no-cache-dir --quiet
              --target /tmp/pydeps
              -r {{ sandstorm_home }}/iss-config-src/requirements.txt
              && exec python3 servermanager.py
          env:
            - name: PYTHONPATH
              value: /tmp/pydeps
          volumeMounts:
            - name: steam-home
              mountPath: {{ sandstorm_home }}
            - name: textfile
              mountPath: {{ monitoring_textfile_dir }}
      volumes:
        # One mount, full parity: game install, mod.io tree, .env, config
        # repo clone and the ~/sandstorm_server symlink all live here and
        # keep their exact systemd-era paths.
        - name: steam-home
          hostPath:
            path: {{ sandstorm_home }}
            type: Directory
        - name: textfile
          hostPath:
            path: {{ monitoring_textfile_dir }}
            type: Directory
