#!/bin/sh
# {{ ansible_managed }}
# The game's ModioBackground thread is a hot polling loop (~50% of a core,
# measured with 0 players). CPUAffinity pins ALL threads of the unit to the
# isolated core, so under load this thread would steal up to half the core
# from the game tick thread. Move it (and only it) to the general cores -
# mod.io background work is not latency-sensitive.
# Runs from a 1-minute timer: idempotent, and re-applies after game restarts.

PID=$(pgrep -f InsurgencyServer-Linux-Shipping | head -1)
[ -z "$PID" ] && exit 0

grep -l ModioBackground /proc/"$PID"/task/*/comm 2>/dev/null | while read -r f; do
    tid=$(basename "$(dirname "$f")")
    taskset -pc {{ host_tuning_general_cpus }} "$tid" >/dev/null 2>&1 || true
done
