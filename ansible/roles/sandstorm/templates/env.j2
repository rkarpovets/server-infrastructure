# Managed by Ansible - do not modify
GAME_DIR={{ sandstorm_install_dir }}
LOG_FILE_PATH={{ sandstorm_install_dir }}/Insurgency/Saved/Logs/Insurgency.log
MAPCYCLE_FILE={{ sandstorm_install_dir }}/Insurgency/Config/Server/MapCycle.txt
GAME_PORT={{ sandstorm_game_port }}
QUERY_PORT={{ sandstorm_query_port }}
RCON_IP={{ sandstorm_rcon_ip }}
RCON_PORT={{ sandstorm_rcon_port }}
RCON_PASSWORD={{ sandstorm_rcon_password }}
GSLT_TOKEN={{ sandstorm_gslt_token }}
GAMESTATS_TOKEN={{ sandstorm_gamestats_token }}
STEAM_API_KEY={{ sandstorm_steam_api_key }}

# Game alerts (Telegram board + Grafana metric). Empty token/chat - disabled.
# SERVER_NAME contains spaces and this file is source'd by server.sh, so the
# value MUST be quoted: unquoted, bash parses "VAR=word more words" as "run
# command 'more' with VAR=word in its env" - the assignment silently fails,
# the game gets an empty -hostname= and its parser once picked the NEXT
# argument (-GSLTToken=...) as the public server name.
SERVER_NAME="{{ sandstorm_server_name }}"
MAX_PLAYERS={{ sandstorm_max_players }}
TELEGRAM_GAME_TOKEN={{ sandstorm_telegram_token }}
TELEGRAM_GAME_CHAT_ID={{ sandstorm_telegram_chat_id }}
BOARD_STATE_FILE={{ sandstorm_install_dir }}/board_message_id.txt
METRICS_FILE={{ sandstorm_metrics_file }}
