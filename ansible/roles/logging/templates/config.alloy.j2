// {{ ansible_managed }}
// Grafana Alloy - the collection agent (successor to Promtail).
// It tails files / the journal and pushes to Loki.

// ---- Where everything ships to ----
loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

{% if logging_collect_iss %}
// ============================================================
//  Insurgency: Sandstorm game log
// ============================================================
local.file_match "iss" {
  path_targets = [{
    __path__ = "/logs/Insurgency.log",
    job      = "sandstorm",
    host     = "{{ inventory_hostname }}",
  }]
}

loki.source.file "iss" {
  targets    = local.file_match.iss.targets
  forward_to = [loki.process.iss.receiver]
}

loki.process "iss" {
  // Drop the noisiest, low-value spam so we don't burn disk/ingest.
  // Tune these patterns to taste - start permissive, tighten later.
  stage.drop {
    // "<< listplayers" is our own RCON poll (every 20s) - pure noise.
    // Kept: "say <name> disconnected" broadcasts (useful leave events).
    expression = ".*(LogNetPackageMap|LogSpawn|VeryVerbose|<< listplayers).*"
  }
  // NOTE: we deliberately keep player names IN THE LOG LINE, never as a
  // label. Labels with unbounded values (player names) explode Loki's
  // index cardinality - the #1 way to kill a Loki instance.
  forward_to = [loki.write.default.receiver]
}

// ============================================================
//  RCON manager sidecar - player join/leave events
// ============================================================
// The manager prints "[JOIN] <name> (<id>)" / "[LEAVE] ..." to stdout, which
// containerd persists under /var/log/containers and later rotates away. It
// gets its OWN Loki stream so retention_stream in loki-config.yml can keep it
// long after the game log expires: ~10 lines an hour, a few MB a year.
//
// The glob deliberately does not use sandstorm_namespace: that variable is a
// default of the sandstorm role, which runs AFTER this one in site.yml.
local.file_match "manager" {
  path_targets = [{
    __path__ = "/var/log/containers/sandstorm-*_manager-*.log",
    job      = "sandstorm-manager",
    host     = "{{ inventory_hostname }}",
  }]
}

loki.source.file "manager" {
  targets    = local.file_match.manager.targets
  forward_to = [loki.process.manager.receiver]
}

loki.process "manager" {
  // containerd writes "<rfc3339> stdout F <line>". Unwrap it so Loki stores the
  // bare line, stamped with the container's own time rather than ingest time.
  stage.cri {}
  // No drop stage, on purpose: every line this container emits is an event
  // worth keeping. The player id stays in the line BODY, never in a label.
  forward_to = [loki.write.default.receiver]
}
{% endif %}

// ============================================================
//  systemd journal - system + service logs
// ============================================================
loki.source.journal "system" {
  max_age       = "12h"
  relabel_rules = loki.relabel.journal.rules
  labels        = {
    job  = "systemd-journal",
    host = "{{ inventory_hostname }}",
  }
  forward_to = [loki.write.default.receiver]
}

loki.relabel "journal" {
  forward_to = []
  // Promote the unit name to a queryable label (bounded set -> safe).
  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
}
