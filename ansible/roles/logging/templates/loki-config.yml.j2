# {{ ansible_managed }}
# Loki - monolithic (single-binary) mode, filesystem storage.
# Right-sized for a single VPS: no object store, no microservices.
auth_enabled: false

server:
  http_listen_port: 3100
  log_level: info

common:
  instance_addr: 127.0.0.1
  path_prefix: /loki
  storage:
    filesystem:
      chunks_directory: /loki/chunks
      rules_directory: /loki/rules
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: 2024-01-01
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: index_
        period: 24h

limits_config:
  retention_period: {{ loki_retention_period }}
  # Guardrails against label-cardinality blowups and runaway ingest
  max_label_names_per_series: 15
  reject_old_samples: true
  reject_old_samples_max_age: 168h
  ingestion_rate_mb: 16
  ingestion_burst_size_mb: 32
  max_streams_per_user: 5000

# The compactor is what actually ENFORCES retention (deletes old chunks).
# Without retention_enabled: true, retention_period above is ignored and
# the disk fills forever - the classic Loki footgun.
compactor:
  working_directory: /loki/compactor
  delete_request_store: filesystem
  retention_enabled: true
  retention_delete_delay: 2h
  compaction_interval: 10m

ruler:
  storage:
    type: local
    local:
      directory: /loki/rules
